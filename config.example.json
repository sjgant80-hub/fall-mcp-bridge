{
  "default_model": "llama3.2",
  "routes": {
    "llama3.2":       { "adapter": "ollama" },
    "qwen2.5":        { "adapter": "ollama" },
    "phi3.5":         { "adapter": "ollama" },
    "femto-16":       { "adapter": "femto" },
    "haiku":          { "adapter": "anthropic", "model": "claude-haiku-4-5" },
    "sonnet":         { "adapter": "anthropic", "model": "claude-sonnet-4-6" },
    "opus":           { "adapter": "anthropic", "model": "claude-opus-4-8" },
    "fable":          { "adapter": "anthropic", "model": "claude-fable-5" },
    "gpt-4o-mini":    { "adapter": "openai" },
    "gpt-4o":         { "adapter": "openai" },
    "gemini-flash":   { "adapter": "openrouter", "model": "google/gemini-2.0-flash-001" },
    "deepseek-v3":    { "adapter": "openrouter", "model": "deepseek/deepseek-chat" },
    "qwen-coder-32b": { "adapter": "lmstudio",   "model": "qwen2.5-coder-32b-instruct" },
    "mlx-llama":      { "adapter": "mlx",        "model": "mlx-community/Llama-3.2-3B-Instruct-4bit" }
  },
  "adapters": {
    "ollama":     { "endpoint": "http://127.0.0.1:11434" },
    "llamacpp":   { "endpoint": "http://127.0.0.1:8080" },
    "mlx":        { "endpoint": "http://127.0.0.1:8000" },
    "lmstudio":   { "endpoint": "http://127.0.0.1:1234" },
    "femto":      { "endpoint": "http://127.0.0.1:1163" },
    "anthropic":  { "apiKey": null },
    "openai":     { "apiKey": null },
    "openrouter": { "apiKey": null }
  },
  "fallback_chain": [
    "llama3.2",
    "haiku",
    "gemini-flash"
  ],
  "_comment": "API keys can be set here OR via env: FALL_MCP_ANTHROPIC_KEY, FALL_MCP_OPENAI_KEY, FALL_MCP_OPENROUTER_KEY (or vendor-native: ANTHROPIC_API_KEY etc). Env wins."
}
